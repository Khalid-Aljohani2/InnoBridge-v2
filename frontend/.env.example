# Laravel API root (no trailing slash). Used by axios as baseURL.
# Local dev example (php artisan serve):
# VITE_API_BASE_URL=http://127.0.0.1:8000
#
# VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=http://127.0.0.1:8000

# Supabase browser client (anon key only; never commit service-role keys).
# Optional until you enable Supabase Auth or direct-from-browser reads guarded by RLS.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
